{
  "extends": [
    "config:base"
  ],
    // Label PRs with `dependencies`.
  "labels": ["dependencies"],
  "enabledManagers": [
    // Enable only the regex manager (for Dockerfile base image bumping).
    "regex"
  ],

  "regexManagers": [
    {
      "fileMatch": [
        ".env$"
      ],
      "datasourceTemplate": "docker",
      "matchStrings": [
        "IMAGE=(?<depName>.+):(?<currentValue>.+)"
      ]
    },
    {
      "fileMatch": [
        "build/Dockerfile$"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "kubeshop/tracetest",
      "matchStrings": [
        "IMAGE_VERSION=(?<currentValue>.+)"
      ]
    },
    {
      "fileMatch": [
        "build/opensearch.yaml$"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "opensearchproject/opensearch",
      "matchStrings": [
        "version: (?<currentValue>.+)"
      ]
    },
    {
      // Parse bundle image version from `base_image` ARG in Dockerfile.
      "fileMatch": [
        "build/container/Dockerfile$"
      ],
      "datasourceTemplate": "docker",
      "matchStrings": [
        "base_image=(?<depName>.+):(?<currentValue>.+)"
      ]
    },
    {
      // Parse version of embedded integrations.
      "fileMatch": [
        "build/embed/integrations.version$"
      ],
      "depNameTemplate": "newrelic/{{{integrationName}}}",
      "datasourceTemplate": "github-releases", // Version info is fetched from GitHub.
      "matchStrings": [
        "(?<integrationName>.+),(?<currentValue>v.+)"
      ]
    },
    {
      "fileMatch": [
        "distributions/otelcol/manifest.yaml$"
      ],
      "datasourceTemplate": "gomod",
      "matchStrings": [
        "gomod: (?<depName>.+) (?<currentValue>.+)"
      ]
    }
  ]
}
