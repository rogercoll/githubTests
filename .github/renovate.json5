{
  extends: [
    'config:recommended',
  ],
  labels: [
    'dependencies',
  ],
  enabledManagers: [
    'custom.regex',
  ],
  "packageRules": [{
    "matchManagers": ["regex"],
    "matchPackagePatterns": ["open-telemetry"],
    "groupName": "otelcol"
  }],
  customManagers: [
    {
      customType: 'regex',
      fileMatch: [
        '.env$',
      ],
      datasourceTemplate: 'docker',
      matchStrings: [
        'IMAGE=(?<depName>.+):(?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      fileMatch: [
        'build/Dockerfile$',
      ],
      datasourceTemplate: 'docker',
      depNameTemplate: 'kubeshop/tracetest',
      matchStrings: [
        'IMAGE_VERSION=(?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      fileMatch: [
        'build/opensearch.yaml$',
      ],
      datasourceTemplate: 'docker',
      depNameTemplate: 'opensearchproject/opensearch',
      matchStrings: [
        'version: (?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      fileMatch: [
        'build/container/Dockerfile$',
      ],
      datasourceTemplate: 'docker',
      matchStrings: [
        'base_image=(?<depName>.+):(?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      fileMatch: [
        'build/embed/integrations.version$',
      ],
      depNameTemplate: 'newrelic/{{{integrationName}}}',
      datasourceTemplate: 'github-releases',
      matchStrings: [
        '(?<integrationName>.+),(?<currentValue>v.+)',
      ],
    },
    {
      customType: 'regex',
      fileMatch: [
        'distributions/otelcol/manifest.yaml$',
      ],
      datasourceTemplate: 'go',
      matchStrings: [
        'gomod: (?<depName>.+) (?<currentValue>.+)',
      ],
    },
  ],
}
