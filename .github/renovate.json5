{
  extends: [
    'config:recommended',
  ],
  labels: [
    'dependencies',
  ],
  gomod: {
    managerFilePatterns: [
     '/(^|/)tools\\.mod$//',
    ],
  },
  enabledManagers: [
    'custom.regex',
    'gomod',
  ],
  packageRules: [
    {
      groupName: 'Go dependencies',
      matchManagers: [
        'gomod',
      ],
    },
    {
      matchManagers: [
        'custom.regex',
      ],
      groupName: 'otelcol',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/.env$/',
      ],
      datasourceTemplate: 'docker',
      matchStrings: [
        'IMAGE=(?<depName>.+):(?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/build/Dockerfile$/',
      ],
      datasourceTemplate: 'docker',
      depNameTemplate: 'kubeshop/tracetest',
      matchStrings: [
        'IMAGE_VERSION=(?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/build/opensearch.yaml$/',
      ],
      datasourceTemplate: 'docker',
      depNameTemplate: 'opensearchproject/opensearch',
      matchStrings: [
        'version: (?<currentValue>.+)',
      ],
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/build/container/Dockerfile$/',
      ],
      datasourceTemplate: 'docker',
      matchStrings: [
        'base_image=(?<depName>.+):(?<currentValue>.+)',
      ],
    },
  ],
}
