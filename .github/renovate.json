{
  "extends": [
    "config:base"
  ],
  "enabledManagers": [
    "regex"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "build/container/Dockerfile$"
      ],
      "datasourceTemplate": "docker",
      "matchStrings": [
        "base_image=(?<depName>.+):(?<currentValue>.+)",
        "ca_certificates=(?<currentValue>.+)"
      ]
    }
  ]
}

